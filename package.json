{
  "name": "storyLint-workspace",
  "version": "1.0.0",
  "description": "Workspace-level package for running Jest tests across chromeExtention and chromeExtention-tests.",
  "scripts": {
    "test:chromeExtention": "cd clients/chromeExtention && npm test",
    "test:chromeExtentionTests": "npx jest --config clients/chromeExtention/jest.config.js",
    "test": "npm run test:chromeExtentionTests"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0"
  }
}
